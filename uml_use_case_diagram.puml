@startuml DnD_AI_Game_Master_Use_Case_Diagram

skinparam defaultFontSize 11
skinparam defaultFontName Arial
skinparam usecase {
    BackgroundColor White
    BorderColor Black
}
skinparam rectangle {
    BackgroundColor White
    BorderColor Black
    FontStyle Bold
    FontSize 14
}
skinparam actor {
    BackgroundColor White
    BorderColor Black
}

top to bottom direction

' ===== Actors =====
actor "Player" as Player

actor "LLM API\n(OpenAI)" as LLM <<service>>
actor "Vector Database\n(ChromaDB)" as VectorDB <<service>>
actor "Image Generation\nService" as ImageGen <<service>>
actor "TTS Service" as TTS <<service>>

' ===== System Boundary =====
rectangle "DnD AI Game Master System" {

    usecase "Configure AI\nParameters" as UC_Config
    usecase "Set Narration Style" as UC_Narration
    usecase "Visit Tavern" as UC_Tavern
    usecase "Manage Inventory" as UC_Inventory
    usecase "Track Quest\nProgress" as UC_Quest

    usecase "Interact with NPCs" as UC_NPC
    usecase "Explore Dungeon" as UC_Explore
    usecase "Engage in Combat" as UC_Combat
    usecase "Attempt Skill Check" as UC_Skill

    usecase "Solve Multi-Stage\nPuzzle" as UC_Puzzle
    usecase "Resolve Complex\nEncounter" as UC_Encounter
    usecase "Plan Enemy Tactics" as UC_Tactics

    usecase "Roll Dice" as UC_Dice
    usecase "Calculate Damage" as UC_Damage
    usecase "Look Up Rules &\nSpell Effects" as UC_Rules

    usecase "Recall Player\nHistory" as UC_PlayerHistory
    usecase "Retrieve Game Lore\n& World Info" as UC_LoreRAG
    usecase "Retrieve Monster\nStats & Lore" as UC_MonsterRAG

    usecase "Generate NPC\nPortrait" as UC_Portrait
    usecase "Voice AI Narration" as UC_Voice
    usecase "Generate Dynamic\nMap" as UC_Map
}

' ===== Player Associations =====
Player -- UC_Config
Player -- UC_Narration
Player -- UC_Tavern
Player -- UC_Inventory
Player -- UC_Quest
Player -- UC_NPC
Player -- UC_Explore
Player -- UC_Combat
Player -- UC_Skill
Player -- UC_Puzzle

' ===== Service Associations =====
UC_NPC -- LLM
UC_Combat -- LLM
UC_Explore -- LLM
UC_Encounter -- LLM

UC_MonsterRAG -- VectorDB
UC_PlayerHistory -- VectorDB
UC_LoreRAG -- VectorDB

UC_Portrait -- ImageGen
UC_Map -- ImageGen

UC_Voice -- TTS

' ===== <<include>> Relationships =====
UC_Combat ..> UC_Dice : <<include>>
UC_Combat ..> UC_Damage : <<include>>
UC_Combat ..> UC_MonsterRAG : <<include>>
UC_Skill ..> UC_Dice : <<include>>
UC_Encounter ..> UC_Tactics : <<include>>
UC_Encounter ..> UC_Combat : <<include>>
UC_NPC ..> UC_PlayerHistory : <<include>>
UC_Explore ..> UC_LoreRAG : <<include>>
UC_Tavern ..> UC_NPC : <<include>>

' ===== <<extend>> Relationships =====
UC_Portrait ..> UC_NPC : <<extend>>
UC_Voice ..> UC_Explore : <<extend>>
UC_Voice ..> UC_Combat : <<extend>>
UC_Map ..> UC_Explore : <<extend>>
UC_Puzzle ..> UC_Explore : <<extend>>
UC_Rules ..> UC_Combat : <<extend>>

@enduml
